APP_ENV=dev
APP_BASE_URL=https://newsletter-pod-xxxxx.a.run.app
APP_TIMEZONE=Europe/Copenhagen
USE_INMEMORY_ADAPTERS=false
GOOGLE_CLOUD_PROJECT=newsletter-pod

JOB_TRIGGER_TOKEN=sm://newsletter-pod-job-trigger-token
SESSION_SIGNING_SECRET=sm://newsletter-pod-session-signing-secret
SESSION_TTL_HOURS=720
APPLE_CLIENT_ID=com.example.newsletterpod
# Firebase project id for the Android/Flutter client's Firebase Auth ID tokens.
# Leave unset on iOS-only deploys; /v1/auth/firebase returns 400 until configured.
FIREBASE_PROJECT_ID=
SOURCES_FILE=sources.yml

PODCAST_TITLE=Daily Newsletter Digest
PODCAST_DESCRIPTION=Private daily digest generated from multiple newsletter feeds.
PODCAST_AUTHOR=Newsletter Pod
PODCAST_LANGUAGE=en-us

PODCAST_PROVIDER=openai
PODCAST_API_ENABLED=false
PODCAST_API_BASE_URL=https://api.openai.com
PODCAST_API_KEY=sm://openai-api-key
PODCAST_API_TIMEOUT_SECONDS=600
PODCAST_API_POLL_SECONDS=10
PODCAST_TEXT_MODEL=gpt-5.4-mini
PODCAST_TTS_PROVIDER=elevenlabs
PODCAST_TTS_MODEL=gpt-4o-mini-tts
PODCAST_TTS_VOICE=alloy
PODCAST_TTS_INSTRUCTIONS=Speak clearly, at a natural pace, in a concise business-news tone.
ELEVENLABS_API_KEY=sm://elevenlabs-api-key
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_VOICE_PRIMARY_ID=suMMgpGbVcnihP1CcgFS
ELEVENLABS_VOICE_PRIMARY_NAME=Vinnie Chase
ELEVENLABS_VOICE_SECONDARY_ID=RKCbSROXui75bk1SVpy8
ELEVENLABS_VOICE_SECONDARY_NAME=Demi Dreams
PODCAST_HOST_PRIMARY_NAME=Vinnie
PODCAST_HOST_SECONDARY_NAME=Demi
PODCAST_FORMAT=anchor_guest
PODCAST_TONE=calm_analyst
PODCAST_TARGET_MINUTES=6
PODCAST_MAX_MINUTES=8
PODCAST_THIN_DAY_MINUTES=2
PODCAST_BOOTSTRAP_MAX_ITEMS_PER_SOURCE=3

GCS_BUCKET_NAME=newsletter-pod-audio
GCS_PREFIX=episodes
FIRESTORE_COLLECTION_PREFIX=newsletter_pod

ALERT_EMAIL_ENABLED=true
ALERT_EMAIL_FROM=alerts@example.com
ALERT_EMAIL_TO=you@example.com
PUBLISH_SUMMARY_EMAIL_ENABLED=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=alerts@example.com
SMTP_PASSWORD=sm://smtp-password
SMTP_USE_TLS=true

# Weekly digest of in-app feedback. First run sends everything to date; later
# runs cover only what's been submitted since the previous run. Sends even when
# the inbox is empty so the operator gets a heartbeat. Recipient list =
# ALERT_EMAIL_TO + comma-separated extras below (deduplicated).
FEEDBACK_DIGEST_EMAIL_ENABLED=false
FEEDBACK_DIGEST_EXTRA_RECIPIENTS=vincemartin1991@gmail.com

SCHEDULE_START_LOCAL=06:30
SCHEDULE_TARGET_LOCAL=07:00
SCHEDULE_CUTOFF_LOCAL=23:00
RAPID_RETRY_MINUTES=5
PERIODIC_RETRY_MINUTES=30

MAX_FEED_EPISODES=30
WEEKLY_TARGET_LOCAL=07:00
WEEKLY_CUTOFF_LOCAL=11:00
DISPATCH_INTERVAL_MINUTES=15

INBOUND_EMAIL_DOMAIN=theclawcast.com
MAILGUN_WEBHOOK_SIGNING_KEY=sm://mailgun-webhook-signing-key
MAILGUN_API_KEY=sm://mailgun-api-key

# X (Twitter) API — OAuth 1.0a user-context credentials. Used by the
# broadcast-loop poster (later phase) to publish generated episodes as
# tweets with media. Free dev tier is sufficient for write; reply
# ingestion requires Basic ($200/mo). Not consumed by Phase 0.
X_API_KEY=sm://x-api-key
X_API_SECRET=sm://x-api-secret
X_ACCESS_TOKEN=sm://x-access-token
X_ACCESS_TOKEN_SECRET=sm://x-access-token-secret

MAX_SOURCES_SAFETY_CAP=100

# Tier delivery-day caps. All tiers deliver 7 days under the launch model;
# free post-first-month gets only 1 default-voice pod/wk so most days are skipped.
FREE_MAX_DELIVERY_DAYS=7
PRO_MAX_DELIVERY_DAYS=7
MAX_MAX_DELIVERY_DAYS=7

# Episode duration range (5-min cap firm across all tiers).
FREE_MIN_DURATION_MINUTES=3
FREE_MAX_DURATION_MINUTES=5
PRO_MIN_DURATION_MINUTES=3
PRO_MAX_DURATION_MINUTES=5
MAX_MIN_DURATION_MINUTES=3
MAX_MAX_DURATION_MINUTES=5

FREE_MAX_ITEMS_PER_EPISODE=25
PRO_MAX_ITEMS_PER_EPISODE=75
MAX_MAX_ITEMS_PER_EPISODE=75

# Per-week voice-tier quotas. Premium = ElevenLabs; default = OpenAI TTS.
TRIAL_PREMIUM_PODS_TOTAL=5
FREE_FIRST_MONTH_GRACE_DAYS=28
FREE_FIRST_MONTH_PREMIUM_PODS_PER_WEEK=1
FREE_POST_MONTH_DEFAULT_PODS_PER_WEEK=1
PRO_PREMIUM_PODS_PER_WEEK=3
PRO_DEFAULT_PODS_PER_WEEK=4
MAX_PREMIUM_PODS_PER_WEEK=7

CLOUD_TASKS_PROJECT_ID=newsletter-pod
CLOUD_TASKS_LOCATION=europe-west1
CLOUD_TASKS_QUEUE=weekly-podcast-runs
CLOUD_TASKS_SERVICE_ACCOUNT=scheduler@newsletter-pod.iam.gserviceaccount.com

# Launch tier model SKUs (see billing_model_2026_05.md).
APP_STORE_PRO_MONTHLY_PRODUCT_ID=com.newsletterpod.pro.monthly
APP_STORE_PRO_ANNUAL_PRODUCT_ID=com.newsletterpod.pro.annual
APP_STORE_MAX_MONTHLY_PRODUCT_ID=com.newsletterpod.max.monthly
APP_STORE_MAX_ANNUAL_PRODUCT_ID=com.newsletterpod.max.annual

# App Store Server Notifications V2 signed-payload verification.
# Set APP_STORE_APP_APPLE_ID to the numeric id from App Store Connect
# once the app record exists; required when environment="production".
# Flip APP_STORE_NOTIFICATIONS_REQUIRE_SIGNED to true before launch so
# the endpoint rejects any unsigned POSTs.
APP_STORE_BUNDLE_ID=com.newsletterpod.app
APP_STORE_ENVIRONMENT=sandbox
# APP_STORE_APP_APPLE_ID=
APP_STORE_NOTIFICATIONS_REQUIRE_SIGNED=false

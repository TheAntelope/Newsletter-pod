# Browser-automation Chrome profile used by scripts/looker/build_dashboard.py.
# Holds Google session cookies — never commit.
.playwright-profile/

# design-tokens/ is a submodule (TheAntelope/clawcast-tokens) — its own
# .gitignore handles node_modules. Keep ios/NewsletterPodApp/DesignTokens.swift
# committed so Xcode builds don't need npm; CI refreshes it from the submodule.

# Local Claude Code workspace: ignore screenshots / lock files / etc.,
# but keep settings.json under version control so project hooks travel
# with the repo. Use `.claude/*` (not `.claude/`) so the negation below
# can take effect — Git skips traversal entirely for an ignored dir.
.claude/*
!.claude/settings.json

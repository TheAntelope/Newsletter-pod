.pytest_cache/
*.pyc
*.pyo
*.pyd
*.egg-info/
.venv/
uv.lock
.env
.DS_Store
.feed_token.bin
.job_token.bin
.job_token.txt
.gcloud-proxy*.log
.uvicorn*.log
tmp-live-episode.mp3
sample_episode.mp3
welcome_v*.mp3
weekly_changes.json
# Locally downloaded/generated episode audio (date-prefixed briefing files).
20??-??-??_*.mp3
build/
DerivedData/
*.xcworkspace
# The Flutter iOS app is a pure-SPM project (no CocoaPods Podfile to regenerate
# the workspace), so its Xcode workspace must be committed — otherwise CI clones
# have no workspace and `flutter build ipa` fails SPM integration with
# "Xcode workspace not found". Exempt it from the blanket *.xcworkspace ignore.
!flutter/ios/Runner.xcworkspace/
*.xcodeproj/xcuserdata/
*.xcuserstate
ios/build/

# Browser-automation Chrome profile used by scripts/looker/build_dashboard.py.
# Holds Google session cookies — never commit.
.playwright-profile/

# design-tokens/ is a submodule (TheAntelope/clawcast-tokens) — its own
# .gitignore handles node_modules. Keep ios/NewsletterPodApp/DesignTokens.swift
# committed so Xcode builds don't need npm; CI refreshes it from the submodule.

# One-off / local-only helper scripts and their logs — not part of the
# shipped toolset under scripts/. Keep on disk, out of version control.
scripts/*_oneoff.py
scripts/code_review_token_report.py
scripts/run_code_review_report.ps1
scripts/list_prod_users.py
scripts/.code_review_report.log
test_replay_check.py

# Personal Obsidian vault layered on top of the repo (config + notes). Kept
# local-only: durable shared knowledge belongs in NEXT_STEPS.md / the auto-
# memory, not here. notes/ is the contained home for new + daily notes.
.obsidian/
notes/
*.base

# Local Claude Code workspace: ignore screenshots / lock files / etc.,
# but keep settings.json under version control so project hooks travel
# with the repo. Use `.claude/*` (not `.claude/`) so the negation below
# can take effect — Git skips traversal entirely for an ignored dir.
.claude/*
!.claude/settings.json

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>ClawCast</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>app</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<!-- Intentionally NO UIApplicationSceneManifest: we stay on the classic
	     (pre-UIScene) Flutter lifecycle. Flutter 3.44's UIScene template crashes
	     at launch on iOS 26 in scene state-restoration. The window is created
	     from Main.storyboard via UIMainStoryboardFile below. Re-adopt UIScene
	     once Flutter fixes the iOS 26 path. See pubspec.yaml
	     (enable-uiscene-migration: false) and flutter#183586. -->
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>ClawCast uses your location to add local weather to your podcast. You can also type your city instead.</string>
	<!-- Optional per Apple (geolocator references the "Always" location API even
	     though ClawCast only requests when-in-use). Provided to satisfy the
	     static-analysis warning; ClawCast never tracks location in the background. -->
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>ClawCast uses your location to add local weather to your podcast. You can also type your city instead.</string>
	<!-- Dictation (speech_to_text): tapping the mic to speak your preferences,
	     topics, or feedback instead of typing. -->
	<key>NSMicrophoneUsageDescription</key>
	<string>ClawCast uses the microphone so you can dictate your preferences and feedback by voice instead of typing.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>ClawCast uses speech recognition to turn what you say into text when you dictate your preferences and feedback.</string>
	<!-- Required because receive_sharing_intent references the photo library API
	     for shared images/media, even though ClawCast primarily shares article
	     links and text into the app. -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>ClawCast can access your photo library when you share an image or media into the app.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<!-- Share-to-ClawCast (receive_sharing_intent): the host app reads shared
	     items from this App Group container, and the extension reopens the app
	     via the ShareMedia-<bundleid> URL scheme. Hardcoded literal (the plugin
	     reads this exact key) — must match the Share Extension Info.plist and
	     both .entitlements. See docs/ios-share-extension-setup.md. -->
	<key>AppGroupId</key>
	<string>group.com.newsletterpod.shared</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>ShareMedia-$(PRODUCT_BUNDLE_IDENTIFIER)</string>
			</array>
		</dict>
		<!-- Google Sign-In OAuth callback. Value is the REVERSED_CLIENT_ID from
		     GoogleService-Info.plist (Firebase project theclawcast-9a045). -->
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.650971509352-halih7umbmdrk6ljqp9shb8tl89jr699</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
